index 06ddc29..0fe978d 100644
--- a/src/class/fileaccesscheck.cpp
+++ b/src/class/fileaccesscheck.cpp
@@ -22,15 +22,19 @@
 #include <windows.h>
 #endif
 
-#ifdef Q_OS_LINUX
+#if defined(Q_OS_LINUX)
 #include <QDBusArgument>
 #include <QDBusConnection>
 #include <QDBusInterface>
 #include <QDBusReply>
 #include <QDBusVariant>
+#endif
 
+#if defined(Q_OS_LINUX) || defined(Q_OS_MAC)
+#include <QFile>
 #include <grp.h>
 #include <pwd.h>
+#include <sys/stat.h>
 #include <sys/wait.h>
 #include <unistd.h>
 #endif
@@ -250,7 +254,7 @@ bool FileAccessCheck::canStandardUserWriteFile(const QString &filePath) {
     LocalFree(pSD);
     CloseHandle(hAccessToken);
     return accessCheckResult && accessStatus;
-#else
+#elif defined(Q_OS_LINUX)
     auto path = filePath.toUtf8();
     if (geteuid() != 0) {
         return access(path, W_OK) == 0;
@@ -288,5 +292,15 @@ bool FileAccessCheck::canStandardUserWriteFile(const QString &filePath) {
         waitpid(pid, &status, 0);
         return (WIFEXITED(status) && WEXITSTATUS(status) == 0);
     }
+#else
+    auto path = QFile::encodeName(filePath);
+    if (geteuid() != 0) {
+        return ::access(path.constData(), W_OK) == 0;
+    }
+    struct stat st;
+    if (stat(path.constData(), &st) != 0) {
+        return false;
+    }
+    return (st.st_mode & (S_IWGRP | S_IWOTH)) != 0;
 #endif
 }
